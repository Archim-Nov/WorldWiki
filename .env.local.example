NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

NEXT_PUBLIC_SITE_URL=https://your-domain.com

RESEND_API_KEY=re_xxx
CONTACT_FROM_EMAIL=Austrum <noreply@your-domain.com>
CONTACT_TO_EMAIL=owner@your-domain.com

SANITY_WEBHOOK_SECRET=replace_with_random_secret
SANITY_API_WRITE_TOKEN=replace_with_sanity_write_token

# Local writer tool
WRITER_ENABLED=true
WRITER_STORAGE_DIR=.local/writer
WRITER_DEFAULT_PROVIDER=

# Optional: distributed rate limit (recommended in production)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
